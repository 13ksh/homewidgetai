<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="Groq API Key">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Save API Key" />

            <Button
                android:id="@+id/btnGetApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Get Groq API Key"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <Button
                android:id="@+id/btnAddWidget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Add Widget to Home Screen" />

            <Button
                android:id="@+id/btnDiscord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="join 13ksh discord sv"
                android:backgroundTint="#5865F2"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </ScrollView>

    <!-- Disclaimer Text at the Bottom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="This app is not officially affiliated with or certified by Groq, Inc. This app is a third-party client that utilizes the Groq API.\n\n본 앱은 Groq, Inc.와 공식적으로 제휴되거나 인증받은 앱이 아닙니다. 이 앱은 Groq API를 활용하는 서드파티 클라이언트입니다."
        android:textSize="10sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="8dp" />

</LinearLayout>